# Database Configuration
# For local development: POSTGRES_HOST=localhost
# For Docker Compose production: POSTGRES_HOST=postgres (set automatically by compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=talent
# Remote DB tunnel port (when remote-ui or local-matchmaking is running)
POSTGRES_REMOTE_TUNNEL_PORT=15432
POSTGRES_PASSWORD=talent_dev
POSTGRES_DB=talent_matching

# Dagster Configuration
# For Docker Compose production this is set in the Dockerfile (/opt/dagster/dagster_home)
DAGSTER_HOME=/path/to/dagster_home

# LLM Configuration
OPENROUTER_API_KEY=sk-or-...  # Get from https://openrouter.ai/keys
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub API (for future use)
# GITHUB_TOKEN=ghp_...

# Airtable Configuration
AIRTABLE_BASE_ID=appBm4ITQiCAgZnRR
AIRTABLE_TABLE_ID=tblOkLOSo4Zjwp0yF
# Jobs table (e.g. Customers STT with "Job Description Link", "Hiring Job Title")
AIRTABLE_JOBS_TABLE_ID=tbl9KNjT3G08f6oXh
# Matches table (Job, Candidate, Score, Pros, Cons, Rank) - optional, for LLM-refined shortlist details
# AIRTABLE_MATCHES_TABLE_ID=tbl...
# Shared view URL of Matches table - pipeline appends ?filter_Job=<id> so each job links to its matches
# AIRTABLE_MATCHES_VIEW_URL=https://airtable.com/shrXXXXXXXXXX

AIRTABLE_API_KEY=pat...  # Get from https://airtable.com/create/tokens

# Notion (for job description fetch from Notion links)
NOTION_API_KEY=secret_...  # Notion integration token

# Remote server (user@host for SSH tunnel to production Dagster stack)
REMOTE_HOST=root@your-server.com

# Environment (development | production)
ENVIRONMENT=development

# ─── Production Docker Compose ───────────────────────────────────────────────
# To run the full stack:
#   docker compose -f docker-compose.prod.yml up --build -d
#
# The compose file overrides POSTGRES_HOST=postgres and ENVIRONMENT=production
# automatically. All other variables above are read from this .env file.
